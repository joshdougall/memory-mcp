# ── Host binding ──────────────────────────────────────────────────────────────
# Interface to bind on. 127.0.0.1 (default) = loopback only.
# Use 0.0.0.0 only if you have AUTH_TOKEN set and a firewall in front.
MEMORY_MCP_BIND=127.0.0.1

# Port exposed on the host
MEMORY_MCP_HOST_PORT=3106

# ── Auth ──────────────────────────────────────────────────────────────────────
# Optional bearer token. Leave empty to run without auth (loopback-safe).
# Generate one with: openssl rand -hex 32
MEMORY_MCP_AUTH_TOKEN=

# ── Limits ────────────────────────────────────────────────────────────────────
# Warn when entry count exceeds this threshold
MEMORY_MCP_MAX_ENTRIES_WARN=300

# Max version snapshots retained per entry
MEMORY_MCP_MAX_VERSIONS_PER_ENTRY=20

# Container memory cap
MEMORY_MCP_MEM_LIMIT=256m

# ── Internal ──────────────────────────────────────────────────────────────────
# Port the Node process listens on inside the container (no need to change)
MEMORY_MCP_PORT=8000

# Valkey image to use
VALKEY_IMAGE=valkey/valkey:9.0.3
